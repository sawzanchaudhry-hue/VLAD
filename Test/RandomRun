os.environ["QT_QPA_PLATFORM"] = "xcb"

import time
import threading
import pigpio

from motor import Motor
from lidar import Lidar
from faced import FaceDetectionThread
from face_servo import ServoTrackingThread
from face_recognizer import get_face_embedding
from face_db import identify_face
from shania_test_button_ipad import ZoomWebInterface
from bed_thread import BedDetectionThread

# =========================
# CONFIG
# =========================
MEETING_URL = "https://torontomu.zoom.us/j/9436567164?pwd=p61dGw5RlbpT4wk7iPUyI3Rqux5v6T.1"

MATCH_THRESHOLD = 0.75
MATCH_INTERVAL = 1.0
FACE_WAIT_TIMEOUT = 30.0

# Bed approach tuning
BED_MIN_STABLE_COUNT = 5
BED_MIN_WIDTH_CLOSE = 380
BED_MIN_HEIGHT_CLOSE = 220
BED_MAX_APPROACH_STEPS = 3
BED_ROAM_GRACE_SECONDS = 4.0

BED_CENTER_TOL = 40
FRAME_WIDTH_EST = 320
SMALL_TURN_ANGLE = 8.0
SMALL_FORWARD_DIST = 0.25

# =========================
# GLOBAL STATE
# =========================
lock = threading.Lock()

current_state = "idle_at_nursing_station"
status_message = "Roaming and searching for a bed..."
target_room = None

zoom_ready = False
zoom_active = False
show_room1_button = False
show_nursing_station_button = False
show_join_zoom_button = False
show_end_call_button = False

face_thread = None
servo_thread = None
recognition_thread = None
recognition_running = False

face_window_start = None
last_match_time = 0.0
known_patient_name = None

bed_thread = None
bed_watch_thread = None
bed_watch_running = False
stable_bed_count = 0
bed_approach_steps = 0
roam_start_time = None

# =========================
# HARDWARE SETUP
# =========================
pi = pigpio.pi()
if not pi.connected:
    raise RuntimeError("Failed to connect to pigpio daemon")

m = Motor(pi)
m.RUN_MOTORS = True

li = Lidar(m)

# =========================
# UI STATE CALLBACK
# =========================
def get_ui_state():
    with lock:
        return {
            "current_state": current_state,
            "status_message": status_message,
            "target_room": target_room,
            "zoom_ready": zoom_ready,
            "zoom_active": zoom_active,
            "show_room1_button": show_room1_button,
            "show_nursing_station_button": show_nursing_station_button,
            "show_join_zoom_button": show_join_zoom_button,
            "show_end_call_button": show_end_call_button,
            "known_patient_name": known_patient_name,
        }

# =========================
# HELPERS
# =========================
def set_state(
    state=None,
    message=None,
    target=None,
    room1=None,
    nursing=None,
    join_zoom=None,
    end_call=None,
    zoom_is_ready=None,
    zoom_is_active=None,
    patient_name=None,
):
    global current_state, status_message, target_room
    global show_room1_button, show_nursing_station_button
    global show_join_zoom_button, show_end_call_button
    global zoom_ready, zoom_active, known_patient_name

    with lock:
        if state is not None:
            current_state = state
        if message is not None:
            status_message = message
        if target is not None:
            target_room = target
        if room1 is not None:
            show_room1_button = room1
        if nursing is not None:
            show_nursing_station_button = nursing
        if join_zoom is not None:
            show_join_zoom_button = join_zoom
        if end_call is not None:
            show_end_call_button = end_call
        if zoom_is_ready is not None:
            zoom_ready = zoom_is_ready
        if zoom_is_active is not None:
            zoom_active = zoom_is_active
        if patient_name is not None:
            known_patient_name = patient_name

def run_path(path_commands):
    m.RUN_MOTORS = True
    for direction, amount in path_commands:
        if direction == "F":
            m.motorForward(amount)
        elif direction == "B":
            m.motorBackward(amount)
        elif direction == "L":
            m.motorLeftSpin(amount)
        elif direction == "R":
            m.motorRightSpin(amount)
        elif direction == "S":
            m.motorStop(amount)

def start_bed_thread():
    global bed_thread
    if bed_thread is None or not bed_thread.is_alive():
        bed_thread = BedDetectionThread(show_all_labels=False, min_confidence=0.40)
        bed_thread.start()
        print("Bed detection thread started")

def stop_bed_thread():
    global bed_thread
    if bed_thread is not None:
        try:
            bed_thread.stop()
            bed_thread.join(timeout=2)
        except Exception:
            pass
        bed_thread = None
        print("Bed detection thread stopped")

def start_face_and_servo():
    global face_thread, servo_thread

    if face_thread is None or not face_thread.is_alive():
        face_thread = FaceDetectionThread(show_window=False)
        face_thread.start()
        print("Face detection thread started")

    if servo_thread is None or not servo_thread.is_alive():
        servo_thread = ServoTrackingThread(face_thread)
        servo_thread.start()
        print("Servo tracking thread started")

def stop_face_and_servo():
    global face_thread, servo_thread

    if servo_thread is not None:
        try:
            servo_thread.stop()
        except Exception:
            pass
        servo_thread = None

    if face_thread is not None:
        try:
            face_thread.stop()
            face_thread.join(timeout=2)
        except Exception:
            pass
        face_thread = None

def safe_face_crop(result):
    face_seen = result["face_seen"]
    bbox = result["bbox"]
    frame = result["frame"]

    if not face_seen or bbox is None or frame is None:
        return None

    x1, y1, x2, y2 = bbox
    h, w = frame.shape[:2]

    box_w = x2 - x1
    box_h = y2 - y1

    pad_x = int(box_w * 0.15)
    pad_y = int(box_h * 0.20)

    x1 = max(0, x1 - pad_x)
    y1 = max(0, y1 - pad_y)
    x2 = min(w - 1, x2 + pad_x)
    y2 = min(h - 1, y2 + pad_y)

    if x2 <= x1 or y2 <= y1:
        return None

    face_crop = frame[y1:y2, x1:x2]
    if face_crop.size == 0:
        return None

    if face_crop.shape[0] < 30 or face_crop.shape[1] < 30:
        return None

    return face_crop

def bed_is_close_enough(bed_bbox):
    if bed_bbox is None:
        return False

    x1, y1, x2, y2 = bed_bbox
    bed_width = x2 - x1
    bed_height = y2 - y1

    return bed_width >= BED_MIN_WIDTH_CLOSE or bed_height >= BED_MIN_HEIGHT_CLOSE

def approach_bed_once(bed_bbox):
    global bed_approach_steps

    if bed_bbox is None:
        return

    x1, y1, x2, y2 = bed_bbox
    bed_center_x = (x1 + x2) / 2.0
    frame_center_x = FRAME_WIDTH_EST / 2.0

    if bed_center_x < frame_center_x - BED_CENTER_TOL:
        print("Bed is left -> small left turn")
        run_path([("L", SMALL_TURN_ANGLE)])
        time.sleep(0.8)
        return

    if bed_center_x > frame_center_x + BED_CENTER_TOL:
        print("Bed is right -> small right turn")
        run_path([("R", SMALL_TURN_ANGLE)])
        time.sleep(0.8)
        return

    print("Bed centered -> move forward a little")
    run_path([("F", SMALL_FORWARD_DIST)])
    bed_approach_steps += 1
    time.sleep(1.0)

def begin_roaming(message="Roaming and searching for a bed..."):
    global roam_start_time, stable_bed_count, bed_approach_steps

    start_bed_thread()
    stable_bed_count = 0
    bed_approach_steps = 0
    roam_start_time = time.time()

    li.runRandomLogic = True
    set_state(
        state="roaming_for_bed",
        message=message,
        room1=False,
        nursing=False,
        join_zoom=False,
        end_call=False,
        zoom_is_ready=False,
        zoom_is_active=False,
        patient_name=None,
    )
    print("Random roaming started")

def switch_to_face_mode():
    global recognition_thread, recognition_running
    global face_window_start, stable_bed_count, bed_approach_steps

    print("Switching to face mode")

    li.runRandomLogic = False
    try:
        m.motorStop(0)
    except Exception:
        pass

    stop_bed_thread()
    time.sleep(1.0)

    start_face_and_servo()
    time.sleep(2.0)
    face_window_start = time.time()

    set_state(
        state="waiting_for_face",
        message="Looking above the bed for patient...",
        room1=False,
        nursing=False,
        join_zoom=False,
        end_call=False,
    )

    stable_bed_count = 0
    bed_approach_steps = 0

    if recognition_thread is None or not recognition_thread.is_alive():
        recognition_running = True
        recognition_thread = threading.Thread(target=recognition_worker, daemon=True)
        recognition_thread.start()

# =========================
# RECOGNITION WORKER
# =========================
def recognition_worker():
    global recognition_running, last_match_time, face_window_start

    while recognition_running:
        with lock:
            state = current_state

        if state != "waiting_for_face":
            time.sleep(0.2)
            continue

        if face_thread is None:
            time.sleep(0.2)
            continue

        now = time.time()

        if face_window_start is not None and (now - face_window_start) > FACE_WAIT_TIMEOUT:
            set_state(
                state="unknown_patient",
                message="No recognized patient found. Resuming bed search..."
            )
            stop_face_and_servo()
            begin_roaming("Roaming and searching for a bed...")
            time.sleep(1.0)
            continue

        result = face_thread.get_result()
        face_crop = safe_face_crop(result)

        if face_crop is None:
            set_state(
                message="Looking for patient...",
                nursing=True,
                join_zoom=False,
                end_call=False,
            )
            time.sleep(0.2)
            continue

        if now - last_match_time < MATCH_INTERVAL:
            time.sleep(0.05)
            continue

        emb = get_face_embedding(face_crop)
        if emb is None:
            set_state(message="Face detected, checking identity...")
            time.sleep(0.1)
            continue

        name, score = identify_face(emb, threshold=MATCH_THRESHOLD)

        if name is not None:
            set_state(
                state="recognized_patient",
                message=f"Recognized patient: {name}. Ready to connect to doctor.",
                nursing=True,
                join_zoom=True,
                end_call=False,
                zoom_is_ready=True,
                zoom_is_active=False,
                patient_name=name,
            )
        else:
            set_state(
                state="waiting_for_face",
                message="Patient not recognized. Nurse will be contacted if not identified soon.",
                nursing=True,
                join_zoom=False,
                end_call=False,
                zoom_is_ready=False,
                zoom_is_active=False,
                patient_name=None,
            )

        last_match_time = now
        time.sleep(0.1)

# =========================
# BED WATCHER
# =========================
def bed_watch_worker():
    global bed_watch_running, stable_bed_count, bed_approach_steps

    while bed_watch_running:
        with lock:
            state = current_state

        if state != "roaming_for_bed":
            time.sleep(0.2)
            continue

        if roam_start_time is not None and (time.time() - roam_start_time) < BED_ROAM_GRACE_SECONDS:
            time.sleep(0.2)
            continue

        if bed_thread is None:
            time.sleep(0.2)
            continue

        result = bed_thread.get_result()
        bed_bbox = result["bed_bbox"]

        if result["bed_seen"]:
            stable_bed_count += 1
        else:
            stable_bed_count = 0

        if stable_bed_count >= BED_MIN_STABLE_COUNT:
            print("Stable bed detected")
            li.runRandomLogic = False
            m.motorStop(0)

            set_state(
                state="bed_found",
                message="Bed found. Approaching patient...",
                room1=False,
                nursing=False,
                join_zoom=False,
                end_call=False,
            )

            if bed_is_close_enough(bed_bbox):
                print("Bed close enough based on bbox")
                switch_to_face_mode()
                continue

            if bed_approach_steps >= BED_MAX_APPROACH_STEPS:
                print("Approached bed enough times -> switch to face mode")
                switch_to_face_mode()
                continue

            approach_bed_once(bed_bbox)
            stable_bed_count = 0

            li.runRandomLogic = True
            set_state(
                state="roaming_for_bed",
                message="Repositioning toward bed...",
                room1=False,
                nursing=False,
                join_zoom=False,
                end_call=False,
            )
            time.sleep(0.5)
            continue

        time.sleep(0.2)

# =========================
# UI COMMAND HANDLER
# =========================
def handle_command(command):
    print("UI command:", command)

    elif_command = False  # no-op, keeps structure simple if UI sends unused commands

    if command == "start_zoom":
        with lock:
            ready = (current_state == "recognized_patient" and zoom_ready)

        if ready:
            set_state(
                state="zoom_active",
                message="Zoom call active",
                nursing=True,
                join_zoom=False,
                end_call=True,
                zoom_is_ready=True,
                zoom_is_active=True,
            )

    elif command == "end_call":
        stop_face_and_servo()
        begin_roaming("Call finished. Resuming bed search...")

# =========================
# UI
# =========================
zoomUI = ZoomWebInterface(
    meeting_url=MEETING_URL,
    host="0.0.0.0",
    port=5000,
    command_callback=handle_command,
    state_callback=get_ui_state,
)

# =========================
# MAIN
# =========================
if __name__ == "__main__":
    try:
        print("Starting LiDAR...")
        li.runStaticMap()
        print("Waiting for LiDAR to boot up...")
        time.sleep(30)

        start_bed_thread()

        bed_watch_running = True
        bed_watch_thread = threading.Thread(target=bed_watch_worker, daemon=True)
        bed_watch_thread.start()

        begin_roaming()

        zoomUI.start()
        print("run3.py started")
        print("Open iPad page at: http://<PI_IP>:5000")

        while True:
            time.sleep(1)

    except KeyboardInterrupt:
        print("Stopping run3.py")

    finally:
        recognition_running = False
        bed_watch_running = False
        stop_face_and_servo()
        stop_bed_thread()
        try:
            m.motorStop(0)
        except Exception:
            pass
        try:
            pi.stop()
        except Exception:
            pass
